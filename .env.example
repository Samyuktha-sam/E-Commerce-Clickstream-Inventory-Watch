# Core connectivity
KAFKA_BOOTSTRAP_SERVERS=broker:29092
KAFKA_PRODUCER_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=clickstream-events
ALERTS_TOPIC=alerts-notifications
BATCH_RESULTS_TOPIC=batch-results
SPARK_MASTER=spark://spark-master:7077
KAFKA_STARTING_OFFSETS=earliest

# Flash-sale detection defaults (tune lower for local demos if needed)
FLASH_SALE_VIEW_THRESHOLD=100
FLASH_SALE_PURCHASE_THRESHOLD=5
FLASH_SALE_WINDOW_DURATION=10 minutes
FLASH_SALE_SLIDE_DURATION=1 minute

# Storage
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_LAKE_PATH=s3a://clickstream-lake
SPARK_CHECKPOINT_BASE=/opt/spark/checkpoints
SPARK_EXTRA_PACKAGES=org.apache.spark:spark-sql-kafka-0-10_2.13:4.1.1,io.delta:delta-spark_2.13:4.0.0,org.apache.hadoop:hadoop-aws:3.4.2
LOCAL_REPORT_DIR=/opt/airflow/reports

# Optional email delivery (works out of the box with Mailpit in docker-compose)
REPORT_EMAIL_TO=reports@example.com
PRODUCER_INTERVAL_SECONDS=0.5
